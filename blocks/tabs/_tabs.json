{
  "definitions": [
    {
      "title": "Tabs",
      "id": "tabs",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Tabs",
              "filter": "tabs"
            }
          }
        }
      }
    },
    {
      "title": "Tab Item",
      "id": "tab-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Tab Item",
              "model": "tab-item",
              "filter": "tab-content"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "tab-item",
      "fields": [
        {
          "component": "select",
          "name": "variant",
          "label": "Tab Variant",
          "valueType": "string",
          "required": true,
          "options": [
            {
              "name": "Simple Tab",
              "value": "simple"
            },
            {
              "name": "Tiled Tab",
              "value": "tiled"
            },
            {
              "name": "Media Tab",
              "value": "media"
            }
          ]
        },
        {
          "component": "text",
          "name": "tabName",
          "label": "Tab Name",
          "valueType": "string",
          "required": true
        },
        {
          "component": "reference",
          "name": "imageIcon",
          "label": "Image/Icon",
          "valueType": "string",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "variant"
              },
              "tiled"
            ]
          }
        },
        {
          "component": "reference",
          "name": "image",
          "label": "Image",
          "valueType": "string",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "variant"
              },
              "media"
            ]
          }
        },
        {
          "component": "text",
          "name": "altText",
          "label": "Alt Text",
          "valueType": "string",
          "condition": {
            "or": [
              {
                "===": [
                  {
                    "var": "variant"
                  },
                  "tiled"
                ]
              },
              {
                "===": [
                  {
                    "var": "variant"
                  },
                  "media"
                ]
              }
            ]
          }
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "tabs",
      "components": [
        "tab-item"
      ]
    },
    {
      "id": "tab-content",
      "components": [
        "text",
        "image",
        "button",
        "title",
        "hero",
        "cards",
        "cards-product",
        "columns",
        "fragment",
        "megamenu",
        "carousel",
        "story-card",
        "warning-card",
        "menu-cards",
        "carousel-dotted",
        "cross-banner",
        "form",
        "embed-adaptive-form"
      ]
    }
  ]
}
