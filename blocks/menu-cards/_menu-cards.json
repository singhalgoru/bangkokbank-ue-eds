{
    "definitions": [
        {
            "title": "Menu Cards",
            "id": "menu-cards",
            "plugins": {
                "xwalk": {
                    "page": {
                        "resourceType": "core/franklin/components/block/v1/block",
                        "template": {
                            "name": "Menu Cards",
                            "model": "menu-cards",
                            "filter": "menu-cards"
                        }
                    }
                }
            }
        },
        {
            "title": "Menu Card",
            "id": "menu-card",
            "plugins": {
                "xwalk": {
                    "page": {
                        "resourceType": "core/franklin/components/block/v1/block/item",
                        "template": {
                            "name": "Menu Card",
                            "model": "menu-card"
                        }
                    }
                }
            }
        }
    ],
    "models": [
        {
            "id": "menu-cards",
            "fields": [
                {
                    "component": "text",
                    "name": "title",
                    "label": "Menu Cards Title",
                    "valueType": "string"
                }
            ]
        },
        {
            "id": "menu-card",
            "fields": [
                {
                    "component": "text",
                    "name": "title",
                    "label": "Card Title",
                    "valueType": "string",
                    "required": true
                },
                {
                    "component": "reference",
                    "name": "icon",
                    "label": "Icon Image",
                    "valueType": "string",
                    "required": true
                },
                {
                    "component": "aem-content",
                    "name": "link",
                    "label": "Redirection Link",
                    "valueType": "content-reference"
                },
                {
                    "component": "boolean",
                    "label": "Enable download button",
                    "name": "isDownloadButton",
                    "valueType": "boolean",
                    "value": false
                },
                {
                    "...": "../../models/elements/_download.json#/_downloadLinkField",
                    "name": "downloadLink",
                    "condition": { "===": [{ "var": "isDownloadButton" }, true] }
                },
                {
                    "...": "../../models/elements/_download.json#/_downloadLinkTextField",
                    "name": "downloadLinkText",
                    "condition": { "===": [{ "var": "isDownloadButton" }, true] }
                } ,
                {
                    "...": "../../models/elements/_download.json#/_downloadLinkTitleField",
                    "name": "downloadLinkTitle",
                    "condition": { "===": [{ "var": "isDownloadButton" }, true] }
                } 
            ]
        }
    ],
    "filters": [
        {
            "id": "menu-cards",
            "components": [
                "menu-card"
            ],
            "maxItems": 6
        }
    ]
}
