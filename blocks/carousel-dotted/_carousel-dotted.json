{
  "definitions": [
    {
      "title": "Carousel Dotted",
      "id": "carousel-dotted",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Carousel Dotted",
              "model": "carousel-dotted",
              "filter": "carousel-dotted"
            }
          }
        }
      }
    },
    {
      "title": "Carousel Slide",
      "id": "carousel-dotted-slide",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Carousel Slide",
              "model": "carousel-dotted-slide"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "carousel-dotted",
      "fields": [
        {
          "component": "boolean",
          "name": "showDots",
          "label": "Show Dots",
          "valueType": "boolean"
        },
        {
          "component": "select",
          "name": "dotsAlignment",
          "label": "Dots Alignment",
          "valueType": "string",
          "options": [
            { "name": "Left", "value": "left" },
            { "name": "Center", "value": "center" },
            { "name": "Right", "value": "right" }
          ],
          "condition": { "!!": [{ "var": "showDots" }] }
        },
        {
          "component": "select",
          "name": "dotsPosition",
          "label": "Dots Position",
          "valueType": "string",
          "options": [
            { "name": "Inside container", "value": "inside-container" },
            { "name": "Outside container", "value": "outside-container" }
          ],
          "condition": { "!!": [{ "var": "showDots" }] }
        },
        {
          "component": "boolean",
          "name": "showArrowsDots",
          "label": "Show Dots and Arrows",
          "valueType": "boolean",
          "value": false
        },
        {
          "component": "boolean",
          "name": "showLinks",
          "label": "Show Links",
          "valueType": "boolean",
          "value": false
        },
        {
          "...": "../../models/elements/_button-fields.json"
        },
        {
          "component": "boolean",
          "name": "autoScroll",
          "label": "Auto-Scroll",
          "valueType": "boolean",
          "value": false
        },
        {
          "component": "select",
          "name": "scrollTimeDelay",
          "label": "Scroll Time Delay (milliseconds)",
          "valueType": "string",
          "options": [
            { "name": "3 seconds", "value": "3000" },
            { "name": "5 seconds", "value": "5000" },
            { "name": "10 seconds", "value": "10000" }
          ],
          "condition": { "!!": [{ "var": "autoScroll" }] }
        }
      ]
    },
    {
      "id": "carousel-dotted-slide",
      "fields": [
        {
          "component": "boolean",
          "name": "withImage",
          "label": "With Full Background Image",
          "valueType": "boolean",
          "value": false,
          "condition": { "!!": [{ "var": "showDots" }] }
        },
        {
          "component": "text",
          "name": "badgeText",
          "label": "Badge Text",
          "valueType": "string",
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              { "!!": [{ "var": "withImage" }] }
            ]
          }
        },
        {
          "component": "reference",
          "name": "image",
          "label": "Image",
          "valueType": "string",
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              { "!!": [{ "var": "withImage" }] }
            ]
          }
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Description",
          "valueType": "string",
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              { "!!": [{ "var": "withImage" }] }
            ]
          }
        },
        {
          "component": "boolean",
          "name": "withoutImage",
          "label": "Without Image",
          "valueType": "boolean",
          "value": false,
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              { "!": [{ "var": "withImage" }] }
            ]
          }
        },
        {
          "component": "text",
          "name": "headerText",
          "label": "Header Text",
          "valueType": "string",
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              { "!!": [{ "var": "withoutImage" }] }
            ]
          }
        },
        {
          "component": "richtext",
          "name": "defaultText",
          "label": "Default Text",
          "valueType": "string",
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              { "!!": [{ "var": "withoutImage" }] }
            ]
          }
        },
        {
          "component": "boolean",
          "name": "heroBannerImageCarousel",
          "label": "Hero Banner Image Carousel",
          "valueType": "boolean",
          "value": false,
          "condition": { "!!": [{ "var": "showDots" }] }
        },
        {
          "component": "boolean",
          "name": "textAnimationVariant",
          "label": "Text Animation Variant",
          "valueType": "boolean",
          "value": false,
          "condition": { "!!": [{ "var": "showDots" }] }
        },
        {
          "component": "reference",
          "name": "heroImage",
          "label": "Hero Image",
          "multi": false,
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              {
                "or": [
                  { "!!": [{ "var": "heroBannerImageCarousel" }] },
                  { "!!": [{ "var": "textAnimationVariant" }] }
                ]
              }
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Alt",
          "value": "",
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              {
                "or": [
                  { "!!": [{ "var": "heroBannerImageCarousel" }] },
                  { "!!": [{ "var": "textAnimationVariant" }] }
                ]
              }
            ]
          }
        },
        {
          "component": "richtext",
          "name": "title",
          "value": "",
          "label": "Title",
          "valueType": "string",
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              {
                "or": [
                  { "!!": [{ "var": "heroBannerImageCarousel" }] },
                  { "!!": [{ "var": "textAnimationVariant" }] }
                ]
              }
            ]
          }
        },
        {
          "component": "richtext",
          "name": "subtitle",
          "value": "",
          "label": "Sub Title",
          "valueType": "string",
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              {
                "or": [
                  { "!!": [{ "var": "heroBannerImageCarousel" }] },
                  { "!!": [{ "var": "textAnimationVariant" }] }
                ]
              }
            ]
          }
        },
        {
          "component": "aem-content",
          "name": "heroLink",
          "label": "Link",
          "description": "Destination URL for the button",
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              {
                "or": [
                  { "!!": [{ "var": "heroBannerImageCarousel" }] },
                  { "!!": [{ "var": "textAnimationVariant" }] }
                ]
              }
            ]
          }
        },
        {
          "component": "text",
          "name": "heroLinkText",
          "label": "Text",
          "description": "Button label text",
          "required": true,
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              {
                "or": [
                  { "!!": [{ "var": "heroBannerImageCarousel" }] },
                  { "!!": [{ "var": "textAnimationVariant" }] }
                ]
              }
            ]
          }
        },
        {
          "component": "text",
          "name": "heroLinkTitle",
          "label": "Title",
          "description": "Accessibility title attribute (optional)",
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              {
                "or": [
                  { "!!": [{ "var": "heroBannerImageCarousel" }] },
                  { "!!": [{ "var": "textAnimationVariant" }] }
                ]
              }
            ]
          }
        },
        {
          "component": "select",
          "name": "heroLinkType",
          "label": "Type",
          "description": "Button style variant",
          "valueType": "string",
          "value": "",
          "options": [
            { "name": "Primary", "value": "primary" },
            { "name": "Secondary", "value": "secondary" },
            { "name": "Tertiary", "value": "tertiary" }
          ],
          "condition": {
            "and": [
              { "!!": [{ "var": "showDots" }] },
              {
                "or": [
                  { "!!": [{ "var": "heroBannerImageCarousel" }] },
                  { "!!": [{ "var": "textAnimationVariant" }] }
                ]
              }
            ]
          }
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "carousel-dotted",
      "components": ["carousel-dotted-slide"]
    }
  ]
}