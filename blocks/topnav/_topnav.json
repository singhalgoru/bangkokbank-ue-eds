{
	"definitions": [
		{
			"title": "Top Nav",
			"id": "top-nav",
			"plugins": {
				"xwalk": {
					"page": {
						"resourceType": "core/franklin/components/block/v1/block",
						"template": {
							"name": "Top Nav",
							"filter": "top-nav"
						}
					}
				}
			}
		},
		{
			"title": "Top Nav link",
			"id": "top-nav-link",
			"plugins": {
				"xwalk": {
					"page": {
						"resourceType": "core/franklin/components/block/v1/block/item",
						"template": {
							"name": "Top Nav link",
							"model": "top-nav-link",
							"classes": "link-only",
							"label": "{{linkText}}"
						}
					}
				}
			}
		}
	],
	"models": [
		{
			"id": "top-nav-link",
			"fields": [
				{
					"component": "text",
					"name": "linkText",
					"label": "Link Text",
					"description": "Text for the link"
				},
				{
					"component": "aem-content",
					"name": "link",
					"label": "Link",
					"description": "Destination URL"
				},
				{
					"component": "select",
					"name": "classes",
					"value": "link-only",
					"label": "link type",
					"options": [
						{
							"name": "Link only",
							"value": "link-only"
						},
						{
							"name": "Link with Logo",
							"value": "link-logo"
						}
					]
				},
				{
					"component": "reference",
					"valueType": "string",
					"name": "image",
					"label": "Image",
					"value": "",
					"condition": {
						"===": [
							{
								"var": "classes"
							},
							"link-logo"
						]
					}
				}
			]
		}
	],
	"filters": [
		{
			"id": "top-nav",
			"components": [
				"top-nav-link"
			]
		}
	]
}